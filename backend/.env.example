# Copy to .env and fill in. .env is gitignored.
OPENAI_BASE_URL=https://ai-relay.chainbot.io/v1
OPENAI_API_KEY=sk-...
MINIAPP_MODEL=gpt-5.5
PORT=3000

# ── Auth ──
# Where the SPA is served (post-login redirect + OAuth redirect base).
APP_BASE_URL=http://localhost:5180
# Google OAuth (from Google Cloud Console). Leave GOOGLE_CLIENT_ID empty to use
# the dev email sign-in fallback instead. Set DEV_AUTH_ENABLED=true to keep the
# local dev sign-in visible even when Google OAuth is configured.
# Register OAUTH_REDIRECT_URI (defaults to ${APP_BASE_URL}/api/auth/google/callback)
# as an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DEV_AUTH_ENABLED=false
# OAUTH_REDIRECT_URI=http://localhost:5180/api/auth/google/callback
# Secret used to sign the session JWT cookie — set a long random value.
SESSION_SECRET=change-me-to-a-long-random-string
# Existing pre-auth data is claimed by this email on first login (else the very
# first user to sign in inherits it).
BOOTSTRAP_OWNER_EMAIL=
